{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "摸鱼小说阅读器",
  "version": "0.1.0",
  "identifier": "com.moyu.novel-reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "摸鱼小说阅读器",
        "width": 420,
        "height": 560,
        "minWidth": 0,
        "minHeight": 0,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}