{
  "name": "moyu-novel-reader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron": "electron .",
    "dist": "npm run test && npm run build && electron-builder --win portable",
    "test": "vitest run && node --test electron/shortcut.test.cjs && node --test electron/fileReader.test.cjs",
    "test:watch": "vitest",
    "validate:phase5": "python scripts/phase5_validate.py",
    "phase5": "npm run test && npm run build && npm run validate:phase5"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "iconv-lite": "^0.6.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "happy-dom": "^17.4.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2",
    "vue-tsc": "^2.2.8",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.moyu.novel-reader",
    "productName": "摸鱼小说阅读器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}